# Frontend Environment Variables
# ---------------------------------------------------
# Copy this file to .env.local for local development
# In production, set these in the Vercel dashboard
# ---------------------------------------------------

# Backend API base URL (no trailing slash)
# Dev:  leave empty (uses Vite proxy to localhost:8080)
# Prod: https://your-backend-name.onrender.com
VITE_API_BASE_URL=

# WebSocket URL
# Dev:  leave empty (uses Vite proxy /ws → localhost:8080)
# Prod: https://your-backend-name.onrender.com/ws
VITE_WS_URL=
